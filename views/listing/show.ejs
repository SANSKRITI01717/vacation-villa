<% layout("./layouts/boilerplate.ejs") %>

  <body>
    <div class="row">
      <div class="col-8 offset-2">
        <h3>listings in detail</h3>
        <div class="card listing-card">
          <img src="<%=ALLlisting.image.url %>" class="card-img-top show-img" alt="...">
          <div class="card-body ">
            <p class="card-text">
              <i>Owned by <%= ALLlisting.owner.username%></i>
            </p>

            <p class="card-text"><b>
                <%= ALLlisting.title %>
              </b></p>
            <p class="card-text">
              <%= ALLlisting.description%>
            </p>
            <p class="card-text">&#8377;<%= ALLlisting.price.toLocaleString("en-IN")%>
            </p>
            <p class="card-text">
              <%= ALLlisting.location %>
            </p>
            <p class="card-text">
              <%= ALLlisting.country %>
            </p>
            <h2>where you'll be</h2>
            <div id="map" style="height: 350px; width: 100%; border-radius: 1rem;"></div>
            <div class="btn-class offset-2">

              <% if(currUser && ALLlisting.owner._id.equals(currUser._id)){ %>

                <div class="col-1 btn-edit">
                  <a href="/listing/<%= ALLlisting._id%>/edit" class="btn-centre btn btn-dark add-btn">Edit</a>
                </div>
                <div class="col-md-4 btn-delete">
                  <form action="/listing/<%= ALLlisting._id %>?_method=DELETE" method="post">
                    <button class="btn add-btn btn-dark btn-centre">Delete</button>
                  </form>
                </div>

                <% } %>

            </div>
            <hr>

            <div class="review col-8 offset-2 mb-3 mt-3">
              <h1>
                Leave a Review
              </h1>
              <% if(currUser){ %>
                <form action="/listing/<%= ALLlisting._id%>/reviews" method="post" novalidate class="needs-validation">
                  <div class="mb-3 mt-3">
                    
                    <!-- <input type="range" min="1" max="5" id="rating" class="form-range" name="review[rating]"> -->
                  <label for="rating" class="form-lable">Rating</label>
                  <fieldset class="starability-slot">
                   
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                      aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                  </fieldset>
                   </div>
                  <div class="mb-3 mt-3">
                    <label for="comment" class="form-lable">Comment</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                      required>let others know your Experience! </textarea>
                    <div class="invalid-feedback">
                      please submit some review!
                    </div>
                  </div>
                  <button class="btn btn-outline-dark">Submit</button>

                </form>

                <% } %>
            </div>

            <HR>
            </HR>

            <p> <b>View Reviews</b></p>
         <div class="row"> 
            <% for(review of ALLlisting.review){ %>
              <div class="card col-5 offset-2 ms-3 mb-3">
                <div class="card-body">
                  <h5 class="card-title">
                    <%= review.author.username %>
                  </h5>

                  <p class="starability-result card-text" data-rating="<%= review.rating%>">
                    Rated: 3 stars
                  </p>

                  <p class="card-text">
                    <%= review.comment %>
                  </p>

                </div>
                <form action="/listing/<%= ALLlisting._id%>/reviews/<%= review._id %>?_method=DELETE" class="mb-3"
                  method="POST">
                  <button class="btn btn-sm btn-dark">delete</button>
                </form>
              </div>

              <% } %>
          </div>

        </div>
      </div>
    </div>
    <script>
    const mapLocation = "<%= ALLlisting.location %>, <%= ALLlisting.country %>";

    fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(mapLocation)}&format=json`)
        .then(res => res.json())
        .then(data => {
            if(data.length > 0) {
                const lat = data[0].lat;
                const lon = data[0].lon;

                const map = L.map('map').setView([lat, lon], 13);
                
                L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap contributors'
                }).addTo(map);

                L.marker([lat, lon]).addTo(map)
                    .bindPopup("<b><%= ALLlisting.title %></b><br><%= ALLlisting.location %>")
                    .openPopup();
            }
        });
</script>
  </body>